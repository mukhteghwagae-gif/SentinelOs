<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="12dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="12dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BLE DEVICE SCANNER" android:textColor="@color/accent_cyan"
                android:textSize="10sp" android:letterSpacing="0.15"/>

            <!-- IDs must match BleFragment.kt: tv_ble_status, tv_ble_count -->
            <TextView android:id="@+id/tv_ble_status"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ready to scan" android:textColor="@color/text_secondary"
                android:textSize="13sp" android:layout_marginTop="4dp"/>
            <TextView android:id="@+id/tv_ble_count"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Devices: 0" android:textColor="@color/text_primary"
                android:textSize="15sp" android:textStyle="bold" android:layout_marginTop="2dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="10dp">
                <!-- IDs must match BleFragment.kt: btn_ble_scan, btn_ble_clear -->
                <Button android:id="@+id/btn_ble_scan"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Start Scan"
                    android:backgroundTint="@color/accent_cyan"
                    android:textColor="@color/black"
                    android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btn_ble_clear"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Clear"
                    android:backgroundTint="@color/bg_card"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- rv_ble_devices — must match BleFragment.kt -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_ble_devices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="88dp"/>

</LinearLayout>
