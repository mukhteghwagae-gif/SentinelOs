<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SentinelOS" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/bg_surface</item>
        <item name="colorPrimaryVariant">@color/bg_dark</item>
        <item name="colorOnPrimary">@color/accent_cyan</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorSecondaryVariant">@color/accent_cyan_dim</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/alert_red_bright</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <!-- Remove default action bar — we use Toolbar -->
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
    </style>

    <!-- Overlay for dark ActionBar/Toolbar -->
    <style name="ThemeOverlay.SentinelOS.Toolbar" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="colorControlNormal">@color/accent_cyan</item>
    </style>
</resources>
